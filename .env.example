# Get a free API key at https://resend.com (no credit card required).
# Without this, booking/contact form submissions will fail with a clear
# "email service not configured" message instead of silently pretending
# to succeed.
RESEND_API_KEY=

# Optional: once you verify your own domain in Resend, set a matching
# sender address here (e.g. booking@quanvicfoto.com). Until then, leave
# this unset and Resend's shared sandbox sender (onboarding@resend.dev)
# is used automatically.
RESEND_FROM_EMAIL=

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX), found in
# GA4 Admin > Data Streams > your web stream. Without this, GA4 simply
# doesn't load — Vercel Analytics (pageviews + the custom events below)
# still works on its own.
NEXT_PUBLIC_GA_ID=

# Production domain, no trailing slash. Used for canonical URLs, the JSON-LD
# LocalBusiness schema, and sitemap.xml. Defaults to the current Vercel
# deployment URL (https://quanvicfoto-website.vercel.app) — only set this if
# a custom domain is connected later.
NEXT_PUBLIC_SITE_URL=

# Get a free API key at https://aistudio.google.com/apikey (Google account,
# no credit card required — the Gemini API free tier covers this chat
# widget's usage). Without this, the chat widget shows a friendly "not
# available" message instead of erroring.
GEMINI_API_KEY=

# Optional: override the Gemini model (defaults to gemini-2.0-flash, which
# is free-tier eligible). Only needed if that model is ever deprecated.
GEMINI_MODEL=
