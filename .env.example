# Get a free API key at https://resend.com (no credit card required).
# Without this, booking/contact form submissions will fail with a clear
# "email service not configured" message instead of silently pretending
# to succeed.
RESEND_API_KEY=

# Optional: once you verify your own domain in Resend, set a matching
# sender address here (e.g. booking@quanvicfoto.com). Until then, leave
# this unset and Resend's shared sandbox sender (onboarding@resend.dev)
# is used automatically.
RESEND_FROM_EMAIL=

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX), found in
# GA4 Admin > Data Streams > your web stream. Without this, GA4 simply
# doesn't load — Vercel Analytics (pageviews + the custom events below)
# still works on its own.
NEXT_PUBLIC_GA_ID=
